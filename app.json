{
  "expo": {
    "name": "Renewly",
    "slug": "renewly",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "renewly",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/icon.png",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.renewly.app",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Renewly uses the microphone to transcribe what you say into the assistant. Audio stays on your device and is never recorded or uploaded.",
        "NSSpeechRecognitionUsageDescription": "Renewly transcribes your speech on-device to fill the assistant's text field. No audio leaves your device."
      }
    },
    "android": {
      "package": "com.renewly.app",
      "permissions": ["android.permission.RECORD_AUDIO"],
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F7F6F3"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      "expo-secure-store",
      "@react-native-community/datetimepicker",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#F7F6F3",
          "dark": {
            "image": "./assets/splash-icon.png",
            "imageWidth": 200,
            "backgroundColor": "#1A1917"
          }
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#4F46E5"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Renewly needs access to attach a document scan. Photos stay on this device and are never uploaded.",
          "cameraPermission": "Renewly needs the camera to scan a document. Scans stay on this device and are never uploaded."
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Use Face ID to unlock Renewly and your document vault."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
